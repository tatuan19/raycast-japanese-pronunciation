{
  "name": "raycast-japanese-pronunciation",
  "title": "Japanese Pronunciation",
  "description": "Convert Japanese words, kanji, or short sentences into hiragana and katakana pronunciation from Raycast.",
  "icon": "icon.png",
  "author": "colbyfayock",
  "repository": {
    "type": "git",
    "url": "https://github.com/tatuan19/raycast-japanese-pronunciation.git"
  },
  "homepage": "https://github.com/tatuan19/raycast-japanese-pronunciation",
  "bugs": {
    "url": "https://github.com/tatuan19/raycast-japanese-pronunciation/issues"
  },
  "categories": [
    "Productivity"
  ],
  "license": "MIT",
  "commands": [
    {
      "name": "convert-kana",
      "title": "Convert to Kana",
      "subtitle": "Japanese text to hiragana and katakana",
      "description": "Convert Japanese words, kanji, or short sentences into hiragana and katakana",
      "mode": "view"
    }
  ],
  "dependencies": {
    "@raycast/api": "^1.102.7",
    "kuroshiro": "^1.2.0",
    "kuroshiro-analyzer-kuromoji": "^1.1.0",
    "kuromoji": "^0.1.2"
  },
  "devDependencies": {
    "@raycast/eslint-config": "latest",
    "@types/node": "^22.13.10",
    "@types/react": "^18.3.18",
    "eslint": "^9.22.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.2"
  },
  "scripts": {
    "dev": "ray develop",
    "build": "ray build",
    "lint": "ray lint",
    "fix-lint": "ray lint --fix",
    "publish": "ray publish"
  }
}
